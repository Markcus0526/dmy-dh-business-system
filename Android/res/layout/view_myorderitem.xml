<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" android:id="@+id/parent_layout" android:background="@color/grayrare">

    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="320px">
        <view android:layout_width="220px"
              android:layout_height="220px"
              class="com.damytech.utils.SmartImageView.SmartImageView" android:id="@+id/viewPhoto"
              android:layout_centerVertical="true" android:layout_alignParentLeft="true"
              android:layout_marginLeft="20px"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="50px"
                android:id="@+id/lblTitle"
                android:layout_toRightOf="@+id/viewPhoto" android:layout_marginLeft="20px"
                android:layout_marginRight="30px" android:layout_alignParentRight="true" android:gravity="center_vertical|left"
                android:textColor="@color/black" android:textSize="45px" android:singleLine="true"
                android:ellipsize="end" android:layout_alignParentTop="true" android:layout_marginTop="20px"/>
        <TextView
                android:layout_width="fill_parent"
                android:layout_height="80px"
                android:id="@+id/lblData" android:layout_below="@+id/lblTitle"
                android:layout_alignLeft="@+id/lblTitle" android:layout_alignRight="@+id/lblTitle"
                android:layout_marginLeft="20px" android:layout_marginTop="10px" android:maxLines="2"
                android:lines="2" android:ellipsize="end" android:textColor="@color/gray" android:textSize="35px"/>
        <TextView
                android:layout_width="150px"
                android:layout_height="80px"
                android:id="@+id/lblStatus"
                android:layout_alignLeft="@+id/lblTitle" android:textSize="35px" android:textColor="@color/black"
                android:gravity="center_vertical|left" android:layout_alignParentBottom="true"
                android:layout_marginBottom="20px"/>
        <Button
                android:layout_width="200px"
                android:layout_height="fill_parent"
                android:id="@+id/btnGo" android:layout_alignBottom="@+id/lblStatus"
                android:layout_alignRight="@+id/lblData" android:layout_alignTop="@+id/lblStatus"
                android:background="@color/orange" android:textColor="@color/white" android:textSize="35px"
                android:layout_marginTop="10px"/>
        <TextView
                android:layout_width="200px"
                android:layout_height="40px"
                android:id="@+id/lblBuyDate" android:layout_alignRight="@+id/btnGo" android:layout_below="@+id/lblData"
                android:layout_marginTop="10px" android:gravity="center_vertical|right"
                android:textColor="@color/black" android:textSize="35px" android:singleLine="true"
                android:ellipsize="end" android:visibility="visible"/>
        <TextView
                android:layout_width="200px"
                android:layout_height="wrap_content"
                android:id="@+id/lblPrice"
                android:textSize="35px" android:textColor="#C00000"
                android:gravity="left|center_vertical" android:layout_alignTop="@+id/lblBuyDate"
                android:layout_alignBottom="@+id/lblBuyDate" android:layout_alignLeft="@+id/lblTitle"
                android:ellipsize="end" android:singleLine="true" android:visibility="visible"/>
    </RelativeLayout>
</RelativeLayout>

