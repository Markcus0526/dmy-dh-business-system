<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" android:id="@+id/parent_layout" android:background="@color/grayrare">

    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="100px" android:layout_alignParentTop="true"
            android:layout_alignParentLeft="true" android:background="@color/bluelight"
            android:id="@+id/relativeLayout">
        <ImageView
                android:layout_width="40px"
                android:layout_height="70px"
                android:id="@+id/imgBack" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="30px" android:scaleType="fitCenter" android:src="@drawable/leftarrowicon"/>
        <TextView
                android:layout_width="400px"
                android:layout_height="fill_parent"
                android:text="@string/dingdantijiao"
                android:id="@+id/lblTitle" android:layout_centerVertical="true" android:layout_centerHorizontal="true"
                android:gravity="center" android:textColor="@color/white" android:textSize="50px"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" android:layout_below="@+id/relativeLayout"
            android:layout_alignParentLeft="true" android:background="@color/grayrare">
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="403px" android:layout_alignParentTop="true"
                android:layout_alignParentLeft="true" android:layout_marginLeft="30px" android:layout_marginTop="50px"
                android:layout_marginRight="30px" android:background="@drawable/roundgraywhite"
                android:id="@+id/relativeLayout8">
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="100px" android:layout_alignParentTop="true"
                    android:layout_alignParentLeft="true" android:id="@+id/relativeLayout2">
                <TextView
                        android:layout_width="350px"
                        android:layout_height="fill_parent"
                        android:id="@+id/lblName" android:layout_centerVertical="true"
                        android:layout_alignParentLeft="true" android:gravity="center_vertical|left"
                        android:textColor="@color/black" android:textSize="35px" android:layout_marginLeft="30px"
                        android:ellipsize="end" android:singleLine="true"/>
                <TextView
                        android:layout_width="200px"
                        android:layout_height="fill_parent"
                        android:id="@+id/lblPrice" android:layout_centerVertical="true"
                        android:layout_alignParentRight="true" android:singleLine="true"
                        android:textColor="@color/bluelight" android:textSize="35px" android:gravity="center_vertical|right"
                        android:ellipsize="end" android:layout_marginRight="30px"/>
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="1px" android:layout_below="@+id/relativeLayout2"
                    android:layout_alignParentLeft="true" android:id="@+id/relativeLayout3"
                    android:background="@color/graylight">
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="100px" android:layout_below="@+id/relativeLayout3"
                    android:layout_alignParentLeft="true" android:id="@+id/relativeLayout4">
                <TextView
                        android:layout_width="250px"
                        android:layout_height="fill_parent"
                        android:id="@+id/lblCountTitle" android:layout_centerVertical="true"
                        android:layout_alignParentLeft="true" android:layout_marginLeft="30px" android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="35px"/>
                <RelativeLayout
                        android:layout_width="262px"
                        android:layout_height="80px"
                        android:layout_alignParentRight="true" android:layout_marginRight="30px"
                        android:layout_centerVertical="true" android:background="@drawable/roundgraywhite">
                    <Button
                            android:layout_width="80px"
                            android:layout_height="fill_parent"
                            android:text="-"
                            android:id="@+id/btnMinus" android:background="@android:color/transparent"
                            android:textColor="@color/gray" android:textSize="55px" android:textStyle="bold"/>
                    <RelativeLayout
                            android:layout_width="1px"
                            android:layout_height="fill_parent" android:layout_toRightOf="@+id/btnMinus"
                            android:background="@color/graylight" android:id="@+id/rlSeparate1">
                    </RelativeLayout>
                    <TextView
                            android:layout_width="100px"
                            android:layout_height="fill_parent"
                            android:id="@+id/lblCount" android:layout_centerVertical="true"
                            android:layout_toRightOf="@+id/rlSeparate1" android:textColor="@color/gray"
                            android:textSize="35px" android:text="1" android:gravity="center"/>
                    <RelativeLayout
                            android:layout_width="1px"
                            android:layout_height="fill_parent" android:layout_toRightOf="@+id/lblCount"
                            android:background="@color/graylight" android:id="@+id/rlSeparate2">
                    </RelativeLayout>
                    <Button
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:text="+"
                            android:id="@+id/btnPlus" android:textColor="@color/gray" android:textSize="55px"
                            android:textStyle="bold" android:background="@android:color/transparent"
                            android:layout_toRightOf="@+id/rlSeparate2"/>
                </RelativeLayout>
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="1px" android:layout_below="@+id/relativeLayout4"
                    android:layout_alignParentLeft="true" android:background="@color/graylight"
                    android:id="@+id/relativeLayout5">
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="100px" android:layout_below="@+id/relativeLayout5"
                    android:id="@+id/relativeLayout6">
                <TextView
                        android:layout_width="280px"
                        android:layout_height="fill_parent"
                        android:text="@string/dinghuaqian"
                        android:id="@+id/lblMarkTitle" android:layout_centerVertical="true"
                        android:layout_alignParentLeft="true" android:layout_marginLeft="30px" android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="35px"/>
                <ImageView
                        android:layout_width="45px"
                        android:layout_height="40px"
                        android:id="@+id/imgIsMark" android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lblMarkTitle" android:layout_marginLeft="30px"
                        android:scaleType="fitCenter" android:src="@drawable/checked" android:visibility="invisible"/>
                <TextView
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:text="@string/shiyongjifen"
                        android:id="@+id/lblUsedMark"
                        android:layout_toRightOf="@+id/imgIsMark" android:layout_marginRight="30px"
                        android:layout_marginLeft="20px" android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="35px" android:visibility="invisible"/>
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="1px" android:id="@+id/relativeLayout7"
                    android:layout_below="@+id/relativeLayout6" android:background="@color/graylight">
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" android:layout_below="@+id/relativeLayout7">
                <TextView
                        android:layout_width="280px"
                        android:layout_height="fill_parent"
                        android:text="@string/zongjia"
                        android:id="@+id/lblTotalPrice" android:layout_centerVertical="true"
                        android:layout_alignParentLeft="true" android:textSize="35px" android:textColor="@color/gray"
                        android:gravity="center_vertical|left" android:layout_marginLeft="30px"/>
                <TextView
                        android:layout_width="280px"
                        android:layout_height="fill_parent"
                        android:text="@string/shiyongjifen1"
                        android:id="@+id/lblRealUsedMark" android:layout_centerVertical="true"
                        android:layout_alignParentRight="true" android:layout_marginRight="30px"
                        android:gravity="center_vertical|right" android:textColor="@color/orange"
                        android:textSize="35px"/>
            </RelativeLayout>
        </RelativeLayout>
        <TextView
                android:layout_width="fill_parent"
                android:layout_height="100px"
                android:text="@string/bangdingshoujihaoma"
                android:id="@+id/lblLinkTitle"
                android:layout_alignLeft="@+id/relativeLayout8" android:layout_alignRight="@+id/relativeLayout8"
                android:layout_below="@+id/relativeLayout8" android:layout_marginTop="120px" android:gravity="center_vertical|left"
                android:textColor="@color/gray" android:textSize="35px"/>
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="100px" android:layout_below="@+id/lblLinkTitle"
                android:layout_alignLeft="@+id/lblLinkTitle" android:layout_alignRight="@+id/lblLinkTitle"
                android:background="@drawable/roundgraywhite" android:id="@+id/relativeLayout9">
            <TextView
                    android:layout_width="320px"
                    android:layout_height="fill_parent"
                    android:id="@+id/lblLinkPhone" android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true" android:layout_marginLeft="23dp" android:gravity="center_vertical|left"
                    android:textSize="35px" android:textColor="@color/gray"/>
        </RelativeLayout>
        <ImageView
                android:layout_width="50px"
                android:layout_height="45px"
                android:id="@+id/imgReject" android:layout_below="@+id/relativeLayout9"
                android:layout_alignLeft="@+id/relativeLayout9" android:layout_marginTop="40px"
                android:layout_marginLeft="30px" android:scaleType="fitCenter" android:src="@drawable/unchecked"
                android:visibility="invisible"/>
        <TextView
                android:layout_width="200px"
                android:layout_height="wrap_content"
                android:text="@string/suishituikuan"
                android:id="@+id/lblReject" android:layout_alignTop="@+id/imgReject"
                android:layout_toRightOf="@+id/imgReject" android:layout_marginLeft="20px"
                android:layout_alignBottom="@+id/imgReject" android:gravity="center_vertical|left"
                android:textColor="@color/gray" android:textSize="35px" android:visibility="invisible"/>
        <Button
                android:layout_width="500px"
                android:layout_height="100px"
                android:text="@string/tijiaodingdan"
                android:id="@+id/btnUpload" android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true" android:layout_marginBottom="100px"
                android:textColor="@color/white" android:textSize="35px" android:background="@drawable/roundblueblue"/>
    </RelativeLayout>
</RelativeLayout>

