<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" android:id="@+id/parent_layout" android:background="@color/grayrare">

    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="100px" android:layout_alignParentTop="true"
            android:layout_alignParentLeft="true" android:background="@color/bluelight"
            android:id="@+id/relativeLayout">
        <ImageView
                android:layout_width="50px"
                android:layout_height="80px"
                android:id="@+id/imgBack" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="30px" android:scaleType="fitCenter" android:src="@drawable/leftarrowicon"/>
        <TextView
                android:layout_width="400px"
                android:layout_height="fill_parent"
                android:text="@string/chongzhimima"
                android:id="@+id/lblTitle" android:layout_centerVertical="true" android:layout_centerHorizontal="true"
                android:gravity="center" android:textColor="@color/white" android:textSize="50px"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="100px"
            android:layout_alignParentLeft="true" android:layout_marginTop="50px" android:layout_marginLeft="60px"
            android:layout_marginRight="60px" android:background="@drawable/roundgraywhite"
            android:id="@+id/relativeLayout2" android:layout_below="@+id/relativeLayout">

        <ImageView
                android:layout_width="50px"
                android:layout_height="50px"
                android:id="@+id/imgKey1" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="25px" android:scaleType="fitCenter" android:src="@drawable/keyicon"/>
        <EditText
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:ems="10"
                android:id="@+id/txtPass" android:layout_centerVertical="true"
                android:layout_toRightOf="@+id/imgKey1" android:layout_marginLeft="60px"
                android:background="@android:color/transparent" android:paddingRight="20px"
                android:textColor="@color/graylight" android:textSize="35px" android:singleLine="true"
                android:ellipsize="end" android:hint="@string/qingshuruxinmima" android:inputType="textPassword"/>

    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="100px" android:layout_below="@+id/relativeLayout2"
            android:layout_alignLeft="@+id/relativeLayout2" android:layout_alignRight="@+id/relativeLayout2"
            android:id="@+id/relativeLayout3" android:layout_marginTop="40px"
            android:background="@drawable/roundgraywhite">

        <ImageView
                android:layout_width="50px"
                android:layout_height="50px"
                android:id="@+id/imgKey2" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="25px" android:scaleType="fitCenter" android:src="@drawable/keyicon"/>
        <EditText
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:inputType="textPassword"
                android:ems="10"
                android:id="@+id/txtRePass" android:layout_centerVertical="true"
                android:layout_toRightOf="@+id/imgKey2" android:layout_marginLeft="60px"
                android:background="@android:color/transparent" android:paddingRight="20px"
                android:textColor="@color/graylight" android:textSize="35px" android:singleLine="true"
                android:ellipsize="end" android:hint="@string/querenmima"/>

    </RelativeLayout>
    <Button
            android:layout_width="wrap_content"
            android:layout_height="100px"
            android:text="@string/xiayibu"
            android:id="@+id/btnNext"
            android:layout_marginTop="80px" android:layout_below="@+id/relativeLayout3"
            android:layout_alignRight="@+id/relativeLayout2" android:layout_alignLeft="@+id/relativeLayout2"
            android:background="@drawable/roundblueblue" android:textColor="@color/white" android:textSize="35px"/>
</RelativeLayout>

