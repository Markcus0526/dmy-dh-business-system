<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" android:id="@+id/parent_layout" android:background="@android:color/transparent">

    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="100px" android:id="@+id/rlLayout1" android:background="@android:color/transparent">
        <TextView
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:id="@+id/lblData" android:gravity="center" android:textColor="@color/gray"
                android:textSize="35px"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="1px" android:layout_below="@+id/rlLayout1" android:background="@color/graylight">
    </RelativeLayout>
</RelativeLayout>

