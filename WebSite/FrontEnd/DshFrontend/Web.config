<configuration>
  <connectionStrings>
    <add name="DSHConnectionString" connectionString="Data Source=218.25.54.28;Initial Catalog=DSH;Persist Security Info=True;User ID=sa;Password=gidshddprh!123"
      providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="ClientValidationEnabled" value="true"/> 
    <add key="UnobtrusiveJavaScriptEnabled" value="true"/>
